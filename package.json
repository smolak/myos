{
	"name": "myos",
	"version": "0.0.1",
	"description": "Local-first productivity dashboard built with Electrobun",
	"scripts": {
		"test": "bun test --pass-with-no-tests ./src/core/bun ./src/features && vitest run",
		"test:core": "bun test --pass-with-no-tests ./src/core/bun ./src/features",
		"test:ui": "vitest run",
		"test:watch": "bun test --watch --pass-with-no-tests ./src/core/bun ./src/features",
		"test:ui:watch": "vitest",
		"start": "vite build && electrobun dev",
		"dev": "electrobun dev --watch",
		"dev:hmr": "concurrently \"bun run hmr\" \"bun run start\"",
		"hmr": "vite --config vite.config.ts",
		"build:dev": "bun install && electrobun build",
		"build:stable": "vite build && electrobun build --env=stable",
		"build:canary": "vite build && electrobun build --env=canary"
	},
	"dependencies": {
		"electrobun": "1.15.1",
		"nanoid": "^5.1.7",
		"react": "^19.2.5",
		"react-dom": "^19.2.5",
		"react-grid-layout": "^2.2.3"
	},
	"devDependencies": {
		"@tailwindcss/postcss": "^4.2.2",
		"@testing-library/jest-dom": "^6.9.1",
		"@testing-library/react": "^16.3.2",
		"@types/bun": "latest",
		"@types/react": "^19.2.14",
		"@types/react-dom": "^19.2.3",
		"@types/react-grid-layout": "^2.1.0",
		"@types/three": "^0.183.1",
		"@vitejs/plugin-react": "^6.0.1",
		"autoprefixer": "^10.4.27",
		"concurrently": "^9.2.1",
		"jsdom": "^29.0.2",
		"postcss": "^8.5.9",
		"tailwindcss": "^4.2.2",
		"typescript": "^5.9.3",
		"vite": "^8.0.8",
		"vitest": "^4.1.4"
	}
}
